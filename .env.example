# Telegram bot token (BotFather dan oling)
TELEGRAM_BOT_TOKEN=

# Botdan foydalanishga ruxsat berilgan Telegram user ID lar, vergul bilan ajratilgan
# Bo'sh qoldirilsa - HAR KIM foydalana oladi (tavsiya etilmaydi)
# Masalan: ALLOWED_USER_IDS=123456789,987654321
ALLOWED_USER_IDS=

# ==== AI provayderlar API kalitlari (kerak bo'lganlarini to'ldiring) ====

# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# https://openrouter.ai/keys  (bitta kalit orqali yuzlab modellarga kirish)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini